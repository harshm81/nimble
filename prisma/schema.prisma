generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model SyncLog {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  platform       String   @db.VarChar(50)
  jobType        String   @map("job_type") @db.VarChar(100)
  status         String   @db.VarChar(20)
  recordsFetched Int?     @map("records_fetched")
  recordsSaved   Int?     @map("records_saved")
  recordsSkipped Int?     @map("records_skipped")
  errorMessage   String?  @map("error_message") @db.VarChar(500)
  durationMs     Int?     @map("duration_ms")
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(3)
  modifiedAt     DateTime @default(now()) @updatedAt @map("modified_at") @db.DateTime(3)

  @@index([modifiedAt], map: "idx_sync_logs_modified_at")
  @@index([platform, jobType], map: "idx_sync_logs_platform_job_type")
  @@map("sync_logs")
}

model SyncConfig {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  platform        String    @db.VarChar(50)
  jobType         String    @map("job_type") @db.VarChar(100)
  lastSyncedAt    DateTime? @map("last_synced_at") @db.DateTime(3)
  intervalMinutes Int       @map("interval_minutes")
  createdAt       DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  modifiedAt      DateTime  @default(now()) @updatedAt @map("modified_at") @db.DateTime(3)

  @@unique([platform, jobType], name: "platform_job_type")
  @@map("sync_config")
}

model PlatformToken {
  platform    String    @id @db.VarChar(50)
  accessToken String    @map("access_token") @db.LongText
  expiresAt   DateTime? @map("expires_at") @db.DateTime(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  modifiedAt  DateTime  @default(now()) @updatedAt @map("modified_at") @db.DateTime(3)

  @@map("platform_tokens")
}

model Cin7Order {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  cin7Id        Int      @unique @map("cin7_id")
  orderNumber   String   @map("order_number") @db.VarChar(100)
  customerEmail String?  @map("customer_email") @db.VarChar(255)
  cin7MemberId  Int?     @map("cin7_member_id")
  status        String   @db.VarChar(50)
  totalAmount   Decimal  @map("total_amount") @db.Decimal(12, 2)
  taxTotal      Decimal  @map("tax_total") @db.Decimal(12, 2)
  lineItemTotal Decimal  @map("line_item_total") @db.Decimal(12, 2)
  shippingTotal Decimal? @map("shipping_total") @db.Decimal(12, 2)
  paymentTerms  String?  @map("payment_terms") @db.VarChar(100)
  branchId      Int      @map("branch_id")
  currency      String   @db.VarChar(10)
  orderDate     DateTime @map("order_date") @db.DateTime(3)
  modifiedDate  DateTime @map("modified_date") @db.DateTime(3)
  rawData       Json     @map("raw_data")
  syncedAt      DateTime @map("synced_at") @db.DateTime(3)
  createdAt     DateTime @default(now()) @map("created_at") @db.DateTime(3)
  modifiedAt    DateTime @default(now()) @updatedAt @map("modified_at") @db.DateTime(3)

  @@index([customerEmail], map: "cin7_orders_customer_email_idx")
  @@index([status], map: "cin7_orders_status_idx")
  @@index([branchId], map: "cin7_orders_branch_id_idx")
  @@index([orderDate], map: "cin7_orders_order_date_idx")
  @@index([modifiedDate], map: "idx_cin7_orders_modified_date")
  @@index([syncedAt], map: "idx_cin7_orders_synced_at")
  @@map("cin7_orders")
}

